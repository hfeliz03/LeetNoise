{
  "manifest_version": 3,
  "name": "LeetNoise",
  "version": "1.0",
  "description": "Play focus audio from YouTube automatically when you start a LeetCode timer.",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.youtube.com/*",
    "https://www.youtube-nocookie.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/wordmark16.png",
    "32": "assets/wordmark32.png",
    "48": "assets/wordmark48.png",
    "128": "assets/wordmark128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeetNoise",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "youtube-controller.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/sounds/*"
      ],
      "matches": [
        "https://leetcode.com/*"
      ]
    }
  ]
}